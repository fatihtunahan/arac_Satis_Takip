                  <input
                    type="number"
                    name="purchasePrice"
                    id="purchasePrice"
                    min="0"
                    step="0.01"
                    placeholder="1250000"
                    required
                  />
                </label>

                <label>
                  <span>Masraf (TL)</span>
                  <input type="number" name="expenses" id="expenses" min="0" step="0.01" placeholder="25000" />
                </label>

                <label>
                  <span>Hedef satış (TL)</span>
                  <input
                    type="number"
                    name="estimatedSalePrice"
                    id="estimatedSalePrice"
                    min="0"
                    step="0.01"
                    placeholder="1395000"
                  />
                </label>

                <label class="sale-field">
                  <span>Satış tarihi</span>
                  <input type="date" name="saleDate" id="saleDate" />
                </label>

                <label class="sale-field">
                  <span>Satış fiyatı (TL)</span>
                  <input type="number" name="salePrice" id="salePrice" min="0" step="0.01" placeholder="1375000" />
                </label>

                <label class="notes-field">
                  <span>Notlar</span>
                  <textarea
                    name="notes"
                    id="notes"
                    rows="4"
                    placeholder="Ekspertiz, kapora, müşteri notu, parça değişimi..."
                  ></textarea>
                </label>
              </div>

              <div class="form-actions">
                <button type="submit" class="button primary" id="submitButton">Kaydı ekle</button>
                <button type="button" class="button ghost" id="resetFormButton">Temizle</button>
              </div>
            </form>
          </section>

          <section class="panel">
            <div class="panel-heading list-heading">
              <div>
                <p class="section-kicker">Takip listesi</p>
                <h2>Araç portföyü</h2>
              </div>

              <div class="toolbar">
                <label class="search-field">
                  <span class="sr-only">Ara</span>
