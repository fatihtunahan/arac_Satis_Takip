const STORAGE_KEY = "vehicle-tracker-v1";
const currencyFormatter = new Intl.NumberFormat("tr-TR", {
  style: "currency",
  currency: "TRY",
  maximumFractionDigits: 0,
});
const dateFormatter = new Intl.DateTimeFormat("tr-TR", {
  day: "2-digit",
  month: "short",
  year: "numeric",
});

const statusLabels = {
  stock: "Stokta",
  pending: "Beklemede",
  sold: "Satıldı",
};

const statusDescriptions = {
  stock: "Portföyde bekliyor",
  pending: "Kapora veya karar aşamasında",
  sold: "Satış kaydı tamamlandı",
};

const summaryGrid = document.getElementById("summaryGrid");
const vehicleForm = document.getElementById("vehicleForm");
const vehicleIdInput = document.getElementById("vehicleId");
const formTitle = document.getElementById("formTitle");
const submitButton = document.getElementById("submitButton");
const resetFormButton = document.getElementById("resetFormButton");
const statusInput = document.getElementById("status");
const saleDateInput = document.getElementById("saleDate");
const salePriceInput = document.getElementById("salePrice");
const searchInput = document.getElementById("searchInput");
const statusFilter = document.getElementById("statusFilter");
const sortSelect = document.getElementById("sortSelect");
const exportButton = document.getElementById("exportButton");
const vehicleTableBody = document.getElementById("vehicleTableBody");
const activityList = document.getElementById("activityList");

let vehicles = loadVehicles();

vehicleForm.addEventListener("submit", handleFormSubmit);
resetFormButton.addEventListener("click", resetForm);
statusInput.addEventListener("change", syncSaleFields);
searchInput.addEventListener("input", renderApp);
statusFilter.addEventListener("change", renderApp);
sortSelect.addEventListener("change", renderApp);
exportButton.addEventListener("click", exportCsv);
vehicleTableBody.addEventListener("click", handleRowActions);

syncSaleFields();
renderApp();

function loadVehicles() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    const parsed = raw ? JSON.parse(raw) : [];
    return Array.isArray(parsed) ? parsed : [];
  } catch (error) {
    console.error("Kayıtlar okunamadı:", error);
    return [];
  }
}

function saveVehicles() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(vehicles));
}

function handleFormSubmit(event) {
  event.preventDefault();

  const formData = new FormData(vehicleForm);
  const existingVehicle = vehicles.find((vehicle) => vehicle.id === vehicleIdInput.value);
  const hasSaleRecord = Boolean(formData.get("saleDate")) && readNumber(formData.get("salePrice")) !== null;
  const vehicle = {
    id: existingVehicle?.id || createId(),
    plate: String(formData.get("plate") || "").trim().toUpperCase(),
    brand: String(formData.get("brand") || "").trim(),
    model: String(formData.get("model") || "").trim(),
    year: readNumber(formData.get("year")),
    fuel: String(formData.get("fuel") || "").trim(),
    transmission: String(formData.get("transmission") || "").trim(),
    mileage: readNumber(formData.get("mileage")),
    purchaseDate: String(formData.get("purchaseDate") || ""),
    purchasePrice: readNumber(formData.get("purchasePrice")),
    expenses: readNumber(formData.get("expenses")) || 0,
    estimatedSalePrice: readNumber(formData.get("estimatedSalePrice")),
    saleDate: String(formData.get("saleDate") || ""),
    salePrice: readNumber(formData.get("salePrice")),
    status: hasSaleRecord ? "sold" : String(formData.get("status") || "stock"),
    notes: String(formData.get("notes") || "").trim(),
    createdAt: existingVehicle?.createdAt || new Date().toISOString(),
    updatedAt: new Date().toISOString(),
  };

  if (!vehicle.purchaseDate || vehicle.purchasePrice === null) {
    window.alert("Alış tarihi ve alış fiyatı zorunludur.");
    return;
  }

  if (vehicle.status === "sold" && (!vehicle.saleDate || vehicle.salePrice === null)) {
    window.alert("Satıldı durumunda satış tarihi ve satış fiyatı girilmelidir.");
    return;
  }

  if (vehicle.saleDate && vehicle.purchaseDate && new Date(vehicle.saleDate) < new Date(vehicle.purchaseDate)) {
    window.alert("Satış tarihi, alış tarihinden önce olamaz.");
    return;
  }

  if (existingVehicle) {
    vehicles = vehicles.map((entry) => (entry.id === vehicle.id ? vehicle : entry));
  } else {
    vehicles = [vehicle, ...vehicles];
  }

  saveVehicles();
  resetForm();
  renderApp();
}

function handleRowActions(event) {
  const actionButton = event.target.closest("button[data-action]");
  if (!actionButton) {
    return;
  }

  const vehicleId = actionButton.dataset.id;
  const vehicle = vehicles.find((entry) => entry.id === vehicleId);
  if (!vehicle) {
    return;
  }

  if (actionButton.dataset.action === "edit") {
    fillForm(vehicle);
    return;
  }

  if (actionButton.dataset.action === "delete") {
    const confirmed = window.confirm(`${vehicle.plate} kaydı silinsin mi?`);
    if (!confirmed) {
      return;
    }

    vehicles = vehicles.filter((entry) => entry.id !== vehicleId);
    saveVehicles();

    if (vehicleIdInput.value === vehicleId) {
      resetForm();
    }

    renderApp();
  }
}

function fillForm(vehicle) {
  vehicleIdInput.value = vehicle.id;
  document.getElementById("plate").value = vehicle.plate || "";
  document.getElementById("brand").value = vehicle.brand || "";
  document.getElementById("model").value = vehicle.model || "";
  document.getElementById("year").value = vehicle.year ?? "";
  document.getElementById("fuel").value = vehicle.fuel || "";
  document.getElementById("transmission").value = vehicle.transmission || "";
  document.getElementById("mileage").value = vehicle.mileage ?? "";
  document.getElementById("purchaseDate").value = vehicle.purchaseDate || "";
  document.getElementById("purchasePrice").value = vehicle.purchasePrice ?? "";
  document.getElementById("expenses").value = vehicle.expenses ?? "";
  document.getElementById("estimatedSalePrice").value = vehicle.estimatedSalePrice ?? "";
  document.getElementById("saleDate").value = vehicle.saleDate || "";
  document.getElementById("salePrice").value = vehicle.salePrice ?? "";
  document.getElementById("status").value = vehicle.status || "stock";
  document.getElementById("notes").value = vehicle.notes || "";

  formTitle.textContent = `${vehicle.plate} kaydını düzenle`;
  submitButton.textContent = "Güncellemeyi kaydet";
  syncSaleFields();
  window.scrollTo({ top: 0, behavior: "smooth" });
}

function resetForm() {
  vehicleForm.reset();
  vehicleIdInput.value = "";
  formTitle.textContent = "Yeni araç ekle";
  submitButton.textContent = "Kaydı ekle";
  statusInput.value = "stock";
  syncSaleFields();
}

function syncSaleFields() {
  const isSold = statusInput.value === "sold";
  saleDateInput.required = isSold;
  salePriceInput.required = isSold;
}

function renderApp() {
  const filteredVehicles = getFilteredVehicles();
  renderSummary();
  renderTable(filteredVehicles);
  renderActivity();
}

function getFilteredVehicles() {
  const query = searchInput.value.trim().toLocaleLowerCase("tr-TR");
  const selectedStatus = statusFilter.value;

  return [...vehicles]
    .filter((vehicle) => {
      const metrics = getVehicleMetrics(vehicle);
      const matchesStatus = selectedStatus === "all" || metrics.status === selectedStatus;
      const haystack = [vehicle.plate, vehicle.brand, vehicle.model, vehicle.notes]
        .join(" ")
        .toLocaleLowerCase("tr-TR");
      const matchesQuery = !query || haystack.includes(query);
      return matchesStatus && matchesQuery;
    })
    .sort((left, right) => sortVehicles(left, right, sortSelect.value));
}

function sortVehicles(left, right, sortMode) {
  const leftMetrics = getVehicleMetrics(left);
  const rightMetrics = getVehicleMetrics(right);

  if (sortMode === "purchase-desc") {
    return compareDates(right.purchaseDate, left.purchaseDate);
  }

  if (sortMode === "purchase-asc") {
    return compareDates(left.purchaseDate, right.purchaseDate);
  }

  if (sortMode === "net-desc") {
    return (rightMetrics.netResult ?? Number.NEGATIVE_INFINITY) - (leftMetrics.netResult ?? Number.NEGATIVE_INFINITY);
  }

  if (sortMode === "net-asc") {
    return (leftMetrics.netResult ?? Number.POSITIVE_INFINITY) - (rightMetrics.netResult ?? Number.POSITIVE_INFINITY);
  }

  return new Date(right.updatedAt || 0).getTime() - new Date(left.updatedAt || 0).getTime();
}

function renderSummary() {
  const totals = vehicles.reduce(
    (accumulator, vehicle) => {
      const metrics = getVehicleMetrics(vehicle);
      accumulator.totalVehicles += 1;
      accumulator.totalInvestment += metrics.costBasis;

      if (metrics.status === "stock") {
        accumulator.stockCount += 1;
      }

      if (metrics.status === "pending") {
        accumulator.pendingCount += 1;
      }

      if (metrics.status === "sold") {
        accumulator.soldCount += 1;
        accumulator.totalSales += vehicle.salePrice || 0;
        accumulator.realizedNet += metrics.realizedNet || 0;
      } else {
        accumulator.expectedNet += metrics.expectedNet || 0;
      }

      return accumulator;
    },
    {
      totalVehicles: 0,
      stockCount: 0,
      pendingCount: 0,
      soldCount: 0,
      totalInvestment: 0,
      totalSales: 0,
      realizedNet: 0,
      expectedNet: 0,
    }
  );

  const cards = [
    {
      label: "Toplam araç",
      value: String(totals.totalVehicles),
      note: `${totals.stockCount} stokta, ${totals.pendingCount} beklemede`,
      tone: "info",
    },
    {
      label: "Satılan araç",
      value: String(totals.soldCount),
      note: "Satışı tamamlanan kayıtlar",
      tone: "info",
    },
    {
      label: "Toplam yatırım",
      value: formatCurrency(totals.totalInvestment),
      note: "Alış ve masraf toplamı",
      tone: "warning",
    },
    {
      label: "Toplam tahsilat",
      value: formatCurrency(totals.totalSales),
      note: "Gerçekleşen satış gelirleri",
      tone: "info",
    },
    {
      label: "Gerçekleşen kar zarar",
      value: formatSignedCurrency(totals.realizedNet),
      note: "Satılan araçlardan net sonuç",
      tone: totals.realizedNet >= 0 ? "positive" : "warning",
    },
    {
      label: "Beklenen stok sonucu",
      value: formatSignedCurrency(totals.expectedNet),
      note: "Hedef satışlara göre potansiyel",
      tone: totals.expectedNet >= 0 ? "positive" : "warning",
    },
  ];

  summaryGrid.innerHTML = cards
    .map(
      (card) => `
        <article class="summary-card ${card.tone}">
          <p class="summary-label">${escapeHtml(card.label)}</p>
          <p class="summary-value">${escapeHtml(card.value)}</p>
          <p class="summary-note">${escapeHtml(card.note)}</p>
        </article>
      `
    )
    .join("");
}

function renderTable(list) {
  if (!list.length) {
    vehicleTableBody.innerHTML = `
      <tr>
        <td colspan="7">
          <div class="empty-state">
            <strong>Henüz kayıt görünmüyor.</strong>
            <p>Soldaki formdan ilk aracı ekleyerek takip listesini başlatabilirsin.</p>
          </div>
        </td>
      </tr>
    `;
    return;
  }

  vehicleTableBody.innerHTML = list
    .map((vehicle) => {
      const metrics = getVehicleMetrics(vehicle);
      const netClass = metrics.netResult === null ? "" : metrics.netResult >= 0 ? "positive" : "negative";
      const purchaseCaption = vehicle.expenses
        ? `Masraf dahil ${formatCurrency(metrics.costBasis)}`
        : "Ek masraf girilmedi";
      const saleCaption =
        metrics.status === "sold"
          ? "Gerçekleşen satış"
          : vehicle.estimatedSalePrice
            ? `Hedef ${formatCurrency(vehicle.estimatedSalePrice)}`
            : "Satış fiyatı bekleniyor";

      return `
        <tr>
          <td data-label="Araç">
            <div class="vehicle-main">
              <strong>${escapeHtml(vehicle.plate)}</strong>
              <span>${escapeHtml([vehicle.brand, vehicle.model].filter(Boolean).join(" "))}</span>
              <span class="vehicle-detail">${escapeHtml(buildVehicleDetail(vehicle))}</span>
            </div>
          </td>
          <td data-label="Alış">
            <div class="amount-block">
              <span class="amount-value">${escapeHtml(formatCurrency(vehicle.purchasePrice || 0))}</span>
              <span class="amount-caption">${escapeHtml(formatDate(vehicle.purchaseDate))}</span>
              <span class="amount-caption">${escapeHtml(purchaseCaption)}</span>
            </div>
          </td>
          <td data-label="Satış">
            <div class="amount-block">
              <span class="amount-value">${escapeHtml(formatCurrency(vehicle.salePrice ?? vehicle.estimatedSalePrice))}</span>
              <span class="amount-caption">${escapeHtml(formatDate(vehicle.saleDate))}</span>
              <span class="amount-caption">${escapeHtml(saleCaption)}</span>
            </div>
          </td>
          <td data-label="Durum">
            <span class="status-badge ${escapeHtml(metrics.status)}">${escapeHtml(statusLabels[metrics.status] || "Kayıt")}</span>
          </td>
          <td data-label="Net sonuç">
            <div class="amount-block">
              <span class="amount-value ${netClass}">${escapeHtml(
                formatSignedCurrency(metrics.netResult)
              )}</span>
              <span class="amount-caption">${escapeHtml(metrics.netLabel)}</span>
            </div>
          </td>
          <td data-label="Bekleme">
            <div class="amount-block">
              <span class="amount-value">${escapeHtml(formatDays(metrics.holdingDays))}</span>
              <span class="hold-note">${escapeHtml(statusDescriptions[metrics.status] || "")}</span>
            </div>
          </td>
          <td data-label="İşlem">
            <div class="row-actions">
              <button type="button" class="button ghost" data-action="edit" data-id="${escapeHtml(vehicle.id)}">Düzenle</button>
              <button type="button" class="button delete" data-action="delete" data-id="${escapeHtml(vehicle.id)}">Sil</button>
            </div>
          </td>
        </tr>
      `;
    })
    .join("");
}

function renderActivity() {
  const activities = vehicles
    .flatMap((vehicle) => {
      const metrics = getVehicleMetrics(vehicle);
      const rows = [];

      if (vehicle.purchaseDate) {
        rows.push({
          id: `${vehicle.id}-purchase`,
          date: vehicle.purchaseDate,
          title: `${vehicle.plate} alış kaydı`,
          detail: `${vehicle.brand} ${vehicle.model}`.trim(),
          amount: -(metrics.costBasis || 0),
        });
      }

      if (metrics.status === "sold" && vehicle.saleDate && vehicle.salePrice !== null) {
        rows.push({
          id: `${vehicle.id}-sale`,
          date: vehicle.saleDate,
          title: `${vehicle.plate} satış kaydı`,
          detail: formatSignedCurrency(metrics.realizedNet),
          amount: vehicle.salePrice,
        });
      }

      return rows;
    })
    .sort((left, right) => compareDates(right.date, left.date))
    .slice(0, 6);

  if (!activities.length) {
    activityList.innerHTML = `
      <li>
        <div class="activity-main">
          <strong>Hareket bulunmuyor</strong>
          <span class="activity-meta">İlk araç kaydı eklendiğinde burada görünür.</span>
        </div>
      </li>
    `;
    return;
  }

  activityList.innerHTML = activities
    .map(
      (activity) => `
        <li>
          <div class="activity-main">
            <strong>${escapeHtml(activity.title)}</strong>
            <span class="activity-meta">${escapeHtml(activity.detail || "Araç işlemi")}</span>
          </div>
          <span class="activity-meta">${escapeHtml(formatDate(activity.date))}</span>
          <span class="activity-amount ${activity.amount >= 0 ? "positive" : "negative"}">${escapeHtml(
            formatSignedCurrency(activity.amount)
          )}</span>
        </li>
      `
    )
    .join("");
}

function getVehicleMetrics(vehicle) {
  const status = vehicle.saleDate && vehicle.salePrice !== null ? "sold" : vehicle.status || "stock";
  const purchasePrice = vehicle.purchasePrice || 0;
  const expenses = vehicle.expenses || 0;
  const costBasis = purchasePrice + expenses;
  const realizedNet = status === "sold" && vehicle.salePrice !== null ? vehicle.salePrice - costBasis : null;
  const expectedNet = status !== "sold" && vehicle.estimatedSalePrice !== null ? vehicle.estimatedSalePrice - costBasis : null;
  const netResult = realizedNet ?? expectedNet;
  const endDate = status === "sold" && vehicle.saleDate ? vehicle.saleDate : todayAsInputValue();

  return {
    status,
    costBasis,
    realizedNet,
    expectedNet,
    netResult,
    netLabel: realizedNet !== null ? "Gerçekleşen net" : expectedNet !== null ? "Beklenen net" : "Hedef girilmedi",
    holdingDays: vehicle.purchaseDate ? diffInDays(vehicle.purchaseDate, endDate) : null,
  };
}

function exportCsv() {
  if (!vehicles.length) {
    window.alert("Dışa aktarılacak kayıt bulunmuyor.");
    return;
  }

  const headers = [
    "Plaka",
    "Marka",
    "Model",
    "Yıl",
    "Yakıt",
    "Vites",
    "Kilometre",
    "Durum",
    "Alış Tarihi",
    "Alış Fiyatı",
    "Masraf",
    "Hedef Satış",
    "Satış Tarihi",
    "Satış Fiyatı",
    "Net Sonuç",
    "Notlar",
  ];

  const lines = vehicles.map((vehicle) => {
    const metrics = getVehicleMetrics(vehicle);
    return [
      vehicle.plate,
      vehicle.brand,
      vehicle.model,
      vehicle.year ?? "",
      vehicle.fuel,
      vehicle.transmission,
      vehicle.mileage ?? "",
      statusLabels[vehicle.status] || vehicle.status,
      vehicle.purchaseDate,
      vehicle.purchasePrice ?? "",
      vehicle.expenses ?? "",
      vehicle.estimatedSalePrice ?? "",
      vehicle.saleDate,
      vehicle.salePrice ?? "",
      metrics.netResult ?? "",
      vehicle.notes,
    ]
      .map(csvEscape)
      .join(";");
  });

  const csvContent = [headers.map(csvEscape).join(";"), ...lines].join("\n");
  const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
  const downloadUrl = URL.createObjectURL(blob);
  const link = document.createElement("a");
  link.href = downloadUrl;
  link.download = `arac-takip-${todayAsInputValue()}.csv`;
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
  URL.revokeObjectURL(downloadUrl);
}

function readNumber(value) {
  if (value === null || value === undefined || value === "") {
    return null;
  }

  const number = Number(value);
  return Number.isFinite(number) ? number : null;
}

function buildVehicleDetail(vehicle) {
  return [vehicle.year, vehicle.fuel, vehicle.transmission, vehicle.mileage ? `${formatNumber(vehicle.mileage)} km` : ""]
    .filter(Boolean)
    .join(" • ");
}

function compareDates(left, right) {
  return new Date(left || 0).getTime() - new Date(right || 0).getTime();
}

function diffInDays(startDate, endDate) {
  const start = new Date(startDate);
  const end = new Date(endDate);
  start.setHours(0, 0, 0, 0);
  end.setHours(0, 0, 0, 0);
  const difference = end.getTime() - start.getTime();
  return difference >= 0 ? Math.round(difference / 86400000) : null;
}

function formatCurrency(value) {
  return value === null || value === undefined ? "-" : currencyFormatter.format(value);
}

function formatSignedCurrency(value) {
  if (value === null || value === undefined) {
    return "-";
  }

  if (value === 0) {
    return currencyFormatter.format(0);
  }

  return `${value > 0 ? "+" : "-"}${currencyFormatter.format(Math.abs(value))}`;
}

function formatDate(value) {
  if (!value) {
    return "-";
  }

  return dateFormatter.format(new Date(value));
}

function formatDays(value) {
  if (value === null || value === undefined) {
    return "-";
  }

  return `${value} gün`;
}

function formatNumber(value) {
  return new Intl.NumberFormat("tr-TR").format(value);
}

function csvEscape(value) {
  const stringValue = String(value ?? "");
  return `"${stringValue.replace(/"/g, '""')}"`;
}

function escapeHtml(value) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function createId() {
  if (window.crypto?.randomUUID) {
    return window.crypto.randomUUID();
  }

  return `vehicle-${Date.now()}-${Math.random().toString(16).slice(2)}`;
}

function todayAsInputValue() {
  const now = new Date();
  const year = now.getFullYear();
  const month = String(now.getMonth() + 1).padStart(2, "0");
  const day = String(now.getDate()).padStart(2, "0");
  return `${year}-${month}-${day}`;
}

